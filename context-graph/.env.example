# =============================================================================
# Copy to .env.local for local dev (never commit .env.local).
# In Vercel: Project → Settings → Environment Variables (same names).
# =============================================================================

# ── Neon PostgreSQL (required: graph API + chat SQL) ───────────
# Dashboard → Connect → copy the *pooled* string (ends with pooler host).
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx-pooler.region.aws.neon.tech/neondb?sslmode=require

# ── Ingest / Vercel build (optional) ───────────────────────────
# JSONL root (must contain business_partners/, sales_orders/, …).
#
# Your copy lives here (ingest picks this up automatically when you run npm from context-graph/):
#   C:\Users\prajw\Desktop\dodge-ai-assignment\Dodge-AI-assignment\context-graph\data\sap-o2c-data
# Relative to context-graph/: ./data/sap-o2c-data — you usually do NOT need O2C_DATA_DIR.
# Fallback if that folder is missing: ../../sap-order-to-cash-dataset/sap-o2c-data
#
# Only if you need to override (same path as above — optional duplicate):
# O2C_DATA_DIR=C:\Users\prajw\Desktop\dodge-ai-assignment\Dodge-AI-assignment\context-graph\data\sap-o2c-data

# On Vercel: vercel-build runs ingest first. Set to 1 to skip (e.g. data loaded manually).
# SKIP_INGEST=0

# ── Google Gemini (primary LLM; at least one LLM key required for chat) ──
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Extra Gemini keys, comma-separated — tried in order on rate limits before other providers.
# GEMINI_API_KEYS=

# Provider order on retryable errors (429, etc.). Skip missing keys. "hf" = huggingface.
# LLM_FALLBACK_ORDER=gemini,groq,openrouter,huggingface

# ── Groq (optional fallback) ───────────────────────────────────
# https://console.groq.com/keys
# GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile

# ── OpenRouter (optional fallback) ───────────────────────────────
# https://openrouter.ai/keys
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=google/gemini-2.0-flash-001
# OPENROUTER_SITE_URL=https://your-app.vercel.app

# ── Hugging Face Inference (optional fallback) ─────────────────
# Token needs "Make calls to Inference Providers".
# https://huggingface.co/settings/tokens
# HUGGINGFACE_API_KEY=
# HUGGINGFACE_CHAT_MODEL=meta-llama/Llama-3.2-3B-Instruct:fastest

# =============================================================================
# Vercel checklist
# ─ DATABASE_URL (Production + Preview if you want preview DB)
# ─ GEMINI_API_KEY (+ optional fallbacks)
# ─ Commit sap-o2c-data under context-graph/data/sap-o2c-data for auto-ingest,
#   or set SKIP_INGEST=1 and run npm run ingest locally against that Neon DB once.
# =============================================================================
