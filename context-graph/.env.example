# ── Neon PostgreSQL (required for graph + chat SQL) ─────────────
# Pooled connection string from Neon dashboard → Connect
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require

# ── Google Gemini (primary LLM path) ───────────────────────────
GEMINI_API_KEY=your_gemini_api_key
# Optional: model id from Google AI Studio / docs
GEMINI_MODEL=gemini-2.0-flash

# Optional: multiple keys (comma-separated) — rotates on rate limit before fallbacks
# GEMINI_API_KEYS=key1,key2

# ── Fallback LLMs (optional — reduces rate-limit pain) ─────────
# Order: try each provider left→right on 429 / quota. Skip if key missing.
# LLM_FALLBACK_ORDER=gemini,groq,openrouter

# Groq — https://console.groq.com/keys
# GROQ_API_KEY=gsk_...
# GROQ_MODEL=llama-3.3-70b-versatile

# OpenRouter — https://openrouter.ai/keys
# OPENROUTER_API_KEY=sk-or-v1-...
# OPENROUTER_MODEL=google/gemini-2.0-flash-001
# OPENROUTER_SITE_URL=https://your-deployed-app.example.com
